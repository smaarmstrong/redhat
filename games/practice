#!/usr/bin/env python3
"""
practice — a console trainer for the RHCSA exam objectives.

Runs INSIDE the Rocky practice machine. Each task gives you a real, exam-shaped
job to do on the system; the grader then checks the *end state* (the way the real
exam is scored), not the commands you typed.

Usage:
    practice learn                # teach the next new task, then let you try it
    practice train                # auto-pick what to do next (review or new) and start it
    practice check                # grade the task you're currently on
    practice list                 # all tasks, grouped by domain, with your status
    practice start  <id>          # show a task and set up its starting state
    practice check  <id>          # grade what you did (pass/fail per requirement)
    practice solution <id>        # reveal a reference solution
    practice reset  <id>          # re-run setup to start the task over
    practice status               # your XP, streak, and completion

New to the material? Run `practice learn` — it explains the concept behind the
next task, then sets it up so you can try it. Once you know the ropes, `practice
train` just picks what to practise next (new material or a review) so you don't
have to decide.

<id> can be the full "domain/nn-name" or just the unique trailing name. For
check/solution/reset you can omit <id> to act on the task train/start gave you.

Task and grader scripts change the system, so setup/check/solution run as root
(via sudo if you aren't already root).
"""
import json
import os
import re
import subprocess
import sys
from datetime import date
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
TRACKS = ["foundations", "rhcsa", "rhce"]
STATE = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local/state")) / "rhcsa-trainer/progress.json"

# How the learner invoked us, so hints name a command they can actually run.
# SELF is the runnable path (e.g. ./games/practice) — used for hints that take
# an <id>. INVOKE is what to suggest for the plain verbs: `make <verb>` when run
# under make (MAKELEVEL is set), otherwise the same path.
SELF = sys.argv[0] or "./games/practice"
INVOKE = "make" if os.environ.get("MAKELEVEL") else SELF

# ---- colours ---------------------------------------------------------------
_tty = sys.stdout.isatty()
def c(code, s):
    return f"\033[{code}m{s}\033[0m" if _tty else s
GRN = lambda s: c("32", s)
RED = lambda s: c("31", s)
YEL = lambda s: c("33", s)
BLU = lambda s: c("34", s)
DIM = lambda s: c("2", s)
BLD = lambda s: c("1", s)

# ---- state -----------------------------------------------------------------
def load_state():
    try:
        return json.loads(STATE.read_text())
    except (FileNotFoundError, json.JSONDecodeError):
        return {"tasks": {}, "xp": 0, "streak": {"count": 0, "last": ""},
                "current": None, "recent_picks": []}

def save_state(st):
    STATE.parent.mkdir(parents=True, exist_ok=True)
    STATE.write_text(json.dumps(st, indent=2))

def bump_streak(st):
    today = date.today().isoformat()
    s = st["streak"]
    if s["last"] == today:
        return
    from datetime import date as _d
    last = s.get("last") or ""
    yesterday = (_d.today().toordinal() - 1)
    if last and _d.fromisoformat(last).toordinal() == yesterday:
        s["count"] += 1
    else:
        s["count"] = 1
    s["last"] = today

# ---- spaced repetition -----------------------------------------------------
# Days until the next review, indexed by how many times you've passed the task.
# After the table runs out we keep roughly doubling.
REVIEW_INTERVALS = [1, 3, 7, 16, 35, 75]

def review_interval(reps):
    """Days until the next review after `reps` successful passes (reps >= 1)."""
    i = max(reps, 1) - 1
    if i < len(REVIEW_INTERVALS):
        return REVIEW_INTERVALS[i]
    return REVIEW_INTERVALS[-1] * (2 ** (i - len(REVIEW_INTERVALS) + 1))

def days_overdue(iso_due):
    """How many days past its review date a task is (>=0 means due now).
    None if it has no scheduled review yet."""
    if not iso_due:
        return None
    return date.today().toordinal() - date.fromisoformat(iso_due).toordinal()

def schedule_review(entry, reps):
    """Record the next review date `review_interval(reps)` days out."""
    entry["reps"] = reps
    due = date.fromordinal(date.today().toordinal() + review_interval(reps))
    entry["due"] = due.isoformat()

# ---- task discovery --------------------------------------------------------
def discover():
    tasks = {}
    for track in TRACKS:
        base = REPO / track / "tasks"
        if not base.is_dir():
            continue
        for meta in sorted(base.glob("*/*/meta.json")):
            d = meta.parent
            tid = f"{track}/{d.parent.name}/{d.name}"
            try:
                m = json.loads(meta.read_text())
            except json.JSONDecodeError:
                continue
            m["id"] = tid
            m["dir"] = d
            m["track"] = track
            tasks[tid] = m
    return tasks

def resolve(tasks, ident):
    if ident in tasks:
        return tasks[ident]
    strip = lambda s: re.sub(r"^\d+-", "", s)
    want = strip(ident)
    matches = [t for tid, t in tasks.items()
               if ident == tid.split("/")[-1] or want == strip(tid.split("/")[-1])]
    if len(matches) == 1:
        return matches[0]
    if not matches:
        sys.exit(RED(f"No task matching '{ident}'. Try: practice list"))
    sys.exit(RED(f"'{ident}' is ambiguous: " + ", ".join(t['id'] for t in matches)))

def spare_present():
    if os.environ.get("SPARE_DISK"):
        return True
    return any(Path(p).exists() for p in ("/dev/vdb", "/dev/sdb", "/dev/vdc", "/dev/sdc"))

def runnable(t, have_spare):
    """Can this task's setup actually run in the current environment?"""
    return not ("spare-disk" in t.get("needs", "") and not have_spare)

def prereq_advice(tasks, st, t):
    """SOFT prerequisite pointers. A task's meta.json may list `prereq` — ids of
    foundations lessons it leans on (e.g. sed, vim). If the learner hasn't
    passed one yet, print a one-line nudge to learn it first. Advisory only:
    it NEVER blocks or changes what runs."""
    for pid in t.get("prereq", []):
        p = tasks.get(pid)
        if p is None:                     # allow a short id, same as resolve()
            hits = [x for x in tasks.values() if x["id"].endswith("/" + pid)]
            p = hits[0] if len(hits) == 1 else None
        if p is None or p["id"] == t["id"]:
            continue
        if st["tasks"].get(p["id"], {}).get("status") == "done":
            continue
        short = p["id"].split("/")[-1]
        print(YEL("heads-up") + DIM("  this task uses \"") + p.get("title", short)
              + DIM("\" — new to it? learn it first:  ") + BLD(f"{SELF} learn {short}"))

# ---- what to practise next -------------------------------------------------
# Teaching order for new material: gentle fundamentals first, heavier/assumed-
# knowledge domains later. Keyed by the task's domain directory name; anything
# unlisted sorts last. (Alphabetical order used to make `boot` the 2nd thing a
# beginner ever saw — grub + regex before they'd met grep or an editor.)
DOMAIN_ORDER = {
    # foundations — the shell tools themselves (editor, grep, regex, sed, awk,
    # pipes, find), taught before any exam task assumes them
    "editor": 0, "shell": 1, "text": 2, "search": 3,
    # rhcsa — build the shell/tooling base before the exam objectives lean on it
    "tools": 0, "scripting": 1, "users-groups": 2, "permissions": 3,
    "processes": 4, "software": 5, "services": 6, "scheduling": 7,
    "logging": 8, "networking": 9, "firewall": 10, "remote": 11,
    "tuning": 12, "security": 13, "selinux": 14, "storage": 15,
    "filesystems": 16, "boot": 17, "containers": 18, "deploy": 19,
    "projects": 20,
    # rhce — inventory/config, then playbook basics, then the broader objectives
    "config": 0, "playbooks": 1, "nodes": 2, "content": 3, "roles": 4,
    "collections": 5, "automate": 6, "source-control": 7,
}

def curriculum_key(t):
    """Sort key placing a task in teaching order: (domain rank, then its id)."""
    return (DOMAIN_ORDER.get(t["id"].split("/")[1], 99), t["id"])

def due_reviews(tasks, st, have_spare):
    """Passed tasks whose review date has arrived, most overdue first."""
    out = []
    for tid, entry in st["tasks"].items():
        if entry.get("status") != "done":
            continue
        t = tasks.get(tid)
        if not t or not runnable(t, have_spare):
            continue
        overdue = days_overdue(entry.get("due"))
        if overdue is None or overdue >= 0:      # unscheduled, or due today/earlier
            out.append((overdue if overdue is not None else 0, t))
    out.sort(key=lambda x: -x[0])                # most overdue first
    return [t for _, t in out]

def next_new(tasks, st, have_spare, focus=None):
    """First not-yet-passed task in teaching order (fundamentals first; rhcsa
    track before rhce). An in-progress task counts as not-done, so this resumes
    unfinished work."""
    order = sorted(tasks.values(), key=curriculum_key)
    for track in ([focus] if focus else TRACKS):
        for t in order:
            if t["track"] != track:
                continue
            if st["tasks"].get(t["id"], {}).get("status") == "done":
                continue
            if not runnable(t, have_spare):
                continue
            return t
    return None

def soonest_review(tasks, st):
    """The nearest upcoming (not-yet-due) review, as (days_away, task)."""
    best = None
    for tid, entry in st["tasks"].items():
        if entry.get("status") != "done":
            continue
        t = tasks.get(tid)
        due = entry.get("due")
        if not t or not due:
            continue
        away = -days_overdue(due)
        if away > 0 and (best is None or away < best[0]):
            best = (away, t)
    return best

# ---- running scripts as root ----------------------------------------------
def run_root(script, extra_env=None):
    if not script.exists():
        return 0
    env = dict(os.environ)
    if extra_env:
        env.update(extra_env)
    cmd = ["bash", str(script)]
    if os.geteuid() != 0:
        cmd = ["sudo", "-E", *cmd]
    return subprocess.run(cmd, env=env).returncode

# ---- commands --------------------------------------------------------------
def cmd_list(tasks, st):
    if not tasks:
        print(DIM("No tasks found yet."))
        return
    have_spare = spare_present()
    print()
    for track in TRACKS:
        tt = [t for t in tasks.values() if t["track"] == track]
        if not tt:
            continue
        done = sum(1 for t in tt if st["tasks"].get(t["id"], {}).get("status") == "done")
        print(BLU(BLD(f"━━ {track.upper()} ")) + DIM(f"({done}/{len(tt)} done) ━━━━━━━━━━━━━━━━"))
        by_domain = {}
        for t in tt:
            by_domain.setdefault(t.get("domain", "Misc"), []).append(t)
        for domain in sorted(by_domain):
            print("  " + BLD(domain))
            for t in sorted(by_domain[domain], key=lambda x: x["id"]):
                status = st["tasks"].get(t["id"], {}).get("status", "")
                locked = "spare-disk" in t.get("needs", "") and not have_spare
                if status == "done":
                    mark = GRN("[x]")
                elif locked:
                    mark = YEL("[-]")
                else:
                    mark = DIM("[ ]")
                name = t["id"].split("/")[-1]
                est = t.get("est_min")
                est_s = DIM(f"  ~{est}m") if est else ""
                note = DIM("  (needs spare disk)") if locked else ""
                print(f"    {mark} {name:<24} {DIM(t.get('title',''))}{est_s}{note}")
        print()
    print_status_line(st)
    print(DIM("New to this?  ") + BLD(f"{INVOKE} learn") + DIM("  teaches the next one first."))
    print(DIM("Know it already?  ") + BLD(f"{INVOKE} train") + DIM("  just picks what to practise."))

def print_status_line(st):
    done = sum(1 for t in st["tasks"].values() if t.get("status") == "done")
    streak = st["streak"]["count"]
    unit = "day" if streak == 1 else "days"
    print(f"{BLD('XP')} {st['xp']}   {BLD('Streak')} {streak} {unit}   {BLD('Done')} {done}\n")

def cmd_status(tasks, st):
    print()
    print_status_line(st)
    total = len(tasks)
    done = sum(1 for t in st["tasks"].values() if t.get("status") == "done")
    print(DIM(f"{done}/{total} tasks complete"))

def launch_task(tasks, st, t):
    """Show a task, set up its starting state, and mark it current. Returns True
    on success. Shared by `start` and `train`."""
    if "spare-disk" in t.get("needs", "") and not spare_present():
        print(YEL("This task needs a spare disk, but none was found."))
        print(DIM("Attach a blank disk to the VM, or set SPARE_DISK=/dev/xyz."))
        return False
    print()
    print(BLD(f"{t['domain']} — {t['title']}"))
    print(DIM(f"objective: {t.get('objective','')}"))
    print(DIM(f"id: {t['id']}"))
    print("─" * 60)
    prompt = t["dir"] / "prompt.md"
    if prompt.exists():
        print(prompt.read_text().rstrip())
    print("─" * 60)
    print(DIM("Setting up the starting state..."))
    rc = run_root(t["dir"] / "setup.sh")
    if rc != 0:
        print(RED("setup failed — see output above"))
        return False
    entry = st["tasks"].setdefault(t["id"], {})
    if entry.get("status") != "done":     # a review keeps its 'done' + schedule
        entry["status"] = "in-progress"
    st["current"] = t["id"]
    save_state(st)
    print(GRN("Ready.") + DIM("  Do the task, then:  ") + f"{INVOKE} check")
    return True

def cmd_start(tasks, st, ident):
    launch_task(tasks, st, resolve(tasks, ident))

def ask(msg):
    """Prompt the learner; treat a closed stdin (piped/non-interactive) as Enter."""
    try:
        return input(msg).strip().lower()
    except EOFError:
        print()
        return ""

def parse_lesson(text):
    """Split a lesson into a sequence of beats the tutor walks through:
        ('prose', text)    a chunk of the lecture, printed as-is
        ('pause', None)    a `---` line — wait for the learner before going on
        ('run',  [lines])  a ```run fenced block — run as ONE shell script
    A lesson with none of these markers is just one prose beat (prints as-is).

    Lines inside a ```run block are captured VERBATIM (indentation and blank
    lines preserved) so heredocs, multi-line YAML, and `cd` within the block
    survive — the whole block is executed as a single script by run_lesson."""
    beats, buf, lines, i = [], [], text.splitlines(), 0
    def flush():
        if any(l.strip() for l in buf):
            beats.append(("prose", "\n".join(buf).strip("\n")))
        buf.clear()
    while i < len(lines):
        s = lines[i].strip()
        if s == "---":
            flush(); beats.append(("pause", None)); i += 1
        elif s.startswith("```run"):
            flush(); raw = []; i += 1
            while i < len(lines) and not lines[i].strip().startswith("```"):
                raw.append(lines[i]); i += 1      # verbatim — keep indentation
            i += 1                                 # skip the closing fence
            while raw and not raw[0].strip():  raw.pop(0)    # trim blank edges
            while raw and not raw[-1].strip(): raw.pop()
            if raw:
                beats.append(("run", raw))
        else:
            buf.append(lines[i]); i += 1
    flush()
    return beats

def run_lesson(beats):
    """Walk the learner through a parsed lesson. Prose is paced with pauses; a
    `run` block is shown, then executed live as a SINGLE shell script on the
    practice system (it's throwaway) so the learner sees real output — running
    it whole means heredocs, `cd`, and $(...) within the block all work.
    Returns False if the learner quit early."""
    for kind, payload in beats:
        if kind == "prose":
            print(payload)
        elif kind == "pause":
            if ask(DIM("\n  [Enter to continue · q to stop] ")) in ("q", "quit"):
                return False
            print()
        elif kind == "run":
            print()
            print(BLD("  Your turn — run this:"))
            for line in payload:
                print(GRN("    " + line))
            ans = ask(DIM("  [Enter to run it here · t to type it yourself · s skip · q stop] "))
            if ans in ("q", "quit"):
                return False
            if ans in ("s", "skip"):
                continue
            if ans in ("t", "type"):
                # Hand over a real interactive shell so the learner types it
                # themselves — with genuine Tab autocompletion, history, etc.
                print(DIM("  Shell open — type the command above yourself (Tab autocompletes)."))
                print(DIM("  Run it, then `exit` (or Ctrl-D) to come back to the lesson."))
                subprocess.run(["bash", "-i"])
                print(DIM("  ── back to the lesson " + "─" * 26))
                continue
            print(DIM("  ── output " + "─" * 40))
            subprocess.run(["bash", "-c", "\n".join(payload)])
            print(DIM("  " + "─" * 49))
    return True

def cmd_learn(tasks, st, ident=None, focus=None):
    """Teach a task like a tutor: a paced lecture from learn.md, telling you
    which commands to run as you go, then a solo practice run. With no id, it
    teaches the next new task — the same one `train` would give you."""
    if ident:
        t = resolve(tasks, ident)
    else:
        t = next_new(tasks, st, spare_present(), focus)
        if t is None:
            print(DIM("You've started every task already. "
                      "Revisit a lesson with:  practice learn <id>"))
            return
    short = t["id"].split("/")[-1]
    print()
    print(BLD(f"LESSON — {t['domain']}: {t['title']}"))
    print(DIM(f"objective: {t.get('objective','')}"))
    print(DIM(f"id: {t['id']}"))
    prereq_advice(tasks, st, t)
    print("─" * 60)
    lesson = t["dir"] / "learn.md"
    if not lesson.exists():
        print(DIM("No written lesson for this task yet — read the task, give it a"))
        print(DIM("go, and reveal a worked solution with  ") + f"{INVOKE} solution")
        prompt = t["dir"] / "prompt.md"
        if prompt.exists():
            print("\n" + prompt.read_text().rstrip())
        print("─" * 60)
        if ask(BLD("Set it up so you can try it? ") + DIM("[Enter = yes, q = later] ")) not in ("q", "quit"):
            launch_task(tasks, st, t)
        else:
            print(DIM("When you're ready:  ") + f"{SELF} start {short}")
        return

    # Put the system into the task's starting state first, so the walkthrough's
    # live commands make sense (many tasks set up a scenario for you to fix).
    if runnable(t, spare_present()):
        print(DIM("Setting up a system to follow along on...\n"))
        run_root(t["dir"] / "setup.sh")
        entry = st["tasks"].setdefault(t["id"], {})
        if entry.get("status") != "done":
            entry["status"] = "in-progress"
        st["current"] = t["id"]
        save_state(st)
    else:
        print(YEL("This task needs a spare disk — the commands below won't run "
                  "here,\nbut read along to learn the shape of it.\n"))
    finished = run_lesson(parse_lesson(lesson.read_text()))
    print("─" * 60)
    if not finished:
        print(DIM("Lesson paused. Pick it back up any time:  ") + f"{SELF} learn {short}")
        return
    print(GRN("That's the lesson.") + DIM("  Best way to make it stick is to do it yourself."))
    if ask(BLD("Practice it now, from a clean slate? ") + DIM("[Enter = yes, q = later] ")) not in ("q", "quit"):
        launch_task(tasks, st, t)
    else:
        print(DIM("When you're ready:  ") + f"{SELF} learn {short}" + DIM("  or  ") + f"{SELF} start {short}")

def choose_task(tasks, st, have_spare, focus=None):
    """Decide what to practise next. Pure — no side effects, so it's testable.
    Returns (task, kind, reason). kind is 'review', 'new', or None (nothing to do).

    Reviews take priority once due, but never more than two in a row while new
    material is still waiting, so new content always keeps advancing."""
    reviews = due_reviews(tasks, st, have_spare)
    new_task = next_new(tasks, st, have_spare, focus)
    recent = st.get("recent_picks", [])
    review_wall = len(recent) >= 2 and recent[-1] == "review" and recent[-2] == "review"

    if reviews and not (review_wall and new_task):
        pick, kind = reviews[0], "review"
    elif new_task:
        pick, kind = new_task, "new"
    elif reviews:                     # only reviews left (all new material done)
        pick, kind = reviews[0], "review"
    else:
        return None, None, ""

    if kind == "review":
        overdue = days_overdue(st["tasks"][pick["id"]].get("due"))
        reason = "due for review" if not overdue else f"review — {overdue}d overdue"
    elif st["tasks"].get(pick["id"], {}).get("status") == "in-progress":
        reason = "resume — started but not yet passed"
    else:
        reason = "new material, next in sequence"
    return pick, kind, reason

def cmd_train(tasks, st, focus=None):
    if not tasks:
        print(DIM("No tasks found.")); return
    pick, kind, reason = choose_task(tasks, st, spare_present(), focus)
    if pick is None:
        print()
        print(GRN(BLD("All caught up — nothing due and no new tasks.")))
        nxt = soonest_review(tasks, st)
        if nxt:
            print(DIM(f"Next review ({nxt[1]['title']}) comes due in {nxt[0]}d."))
        print()
        print_status_line(st)
        return
    st["recent_picks"] = (st.get("recent_picks", []) + [kind])[-4:]
    tag = YEL("REVIEW") if kind == "review" else GRN(" NEW  ")
    print()
    print_status_line(st)
    print(f"{tag}  {DIM(reason)}")
    prereq_advice(tasks, st, pick)
    launch_task(tasks, st, pick)

def cmd_check(tasks, st, ident):
    t = resolve(tasks, ident)
    print()
    print(BLD(f"Grading: {t['title']}"))
    rc = run_root(t["dir"] / "grade.sh")
    entry = st["tasks"].setdefault(t["id"], {})
    entry["attempts"] = entry.get("attempts", 0) + 1
    if rc == 0:
        was_review = entry.get("status") == "done"
        entry["status"] = "done"
        entry["completed"] = date.today().isoformat()
        if was_review:
            reps, gain = entry.get("reps", 1) + 1, 5
        else:
            reps, gain = 1, 10 + int(t.get("est_min", 5))
        schedule_review(entry, reps)
        st["xp"] += gain
        bump_streak(st)
        print(GRN(f"\n+{gain} XP") + f"   (streak {st['streak']['count']})")
        print(DIM(f"Next review in {review_interval(reps)}d.  Next task:  ") + f"{INVOKE} train")
    else:
        if entry.get("status") == "done":   # a lapse — relearn from the start, soon
            entry["reps"] = 0
            entry["due"] = date.today().isoformat()
        print(YEL("\nNot passed yet.") + DIM("  Fix it and re-run  ") + f"{INVOKE} check"
              + DIM("   (stuck?  ") + f"{INVOKE} solution" + DIM(")"))
    save_state(st)

def cmd_solution(tasks, st, ident):
    t = resolve(tasks, ident)
    sol = t["dir"] / "solution.sh"
    print()
    print(BLD(f"Reference solution — {t['title']}"))
    print(DIM("(one valid way; the grader accepts any path to the same end state)"))
    print("─" * 60)
    if sol.exists():
        # show it without the boilerplate header lines
        for line in sol.read_text().splitlines():
            if line.startswith("#!") or line.startswith('. "$('):
                continue
            print(line)
    print("─" * 60)

def cmd_reset(tasks, st, ident):
    t = resolve(tasks, ident)
    print(DIM("Resetting task state..."))
    run_root(t["dir"] / "setup.sh")
    st["tasks"].setdefault(t["id"], {})["status"] = "in-progress"
    save_state(st)
    print(GRN("Reset. Starting state restored."))

def main():
    tasks = discover()
    st = load_state()
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help", "help"):
        print(__doc__)
        return
    cmd, rest = args[0], args[1:]
    if cmd == "list":
        cmd_list(tasks, st)
    elif cmd == "status":
        cmd_status(tasks, st)
    elif cmd in ("train", "next"):
        focus = rest[0] if rest and rest[0] in TRACKS else None
        cmd_train(tasks, st, focus)
    elif cmd == "learn":
        if rest and rest[0] in TRACKS:
            cmd_learn(tasks, st, focus=rest[0])
        else:
            cmd_learn(tasks, st, ident=rest[0] if rest else None)
    elif cmd == "start":
        if not rest:
            sys.exit(RED(f"Usage: {SELF} start <id>   (or just: {INVOKE} train)"))
        cmd_start(tasks, st, rest[0])
    elif cmd in ("check", "solution", "reset"):
        ident = rest[0] if rest else st.get("current")
        if not ident:
            sys.exit(RED(f"Nothing to {cmd} — run '{INVOKE} train' first, "
                         f"or name a task: {SELF} {cmd} <id>"))
        {"check": cmd_check, "solution": cmd_solution, "reset": cmd_reset}[cmd](tasks, st, ident)
    else:
        sys.exit(RED(f"Unknown command '{cmd}'. Try: {INVOKE} help"))

if __name__ == "__main__":
    main()
